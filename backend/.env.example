# ── Provider API keys ────────────────────────────────────────────────
OCEAN_API_KEY=
PROSPEO_API_KEY=
EAZYREACH_API_KEY=          # optional; if empty, resolve stage falls back to Prospeo enrich-person

# Brevo: REST needs an API v3 key (xkeysib-...). If you only have an SMTP
# key (xsmtpsib-...), leave transport=auto and set BREVO_SMTP_LOGIN.
BREVO_API_KEY=
BREVO_TRANSPORT=auto        # auto | rest | smtp
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=           # your Brevo account login email (required for smtp transport)

# ── Sender identity (must be a verified sender on your domain) ────────
SENDER_EMAIL=outreach@debanshupaul.me
SENDER_NAME=Debanshu Paul
REPLY_TO_EMAIL=

# ── Pipeline tuning ──────────────────────────────────────────────────
MOCK=false                  # true = use fake providers, spend zero credits
MAX_COMPANIES=15
MAX_CONTACTS_PER_COMPANY=5
PROSPECT_CONCURRENCY=5
RESOLVE_CONCURRENCY=5
SEND_CONCURRENCY=3

# ── Rate limits (requests/sec per provider, global token bucket) ─────
OCEAN_RPS=2
PROSPEO_RPS=2
EAZYREACH_RPS=2
BREVO_RPS=5

# ── Cache ────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_DIR=.cache
CACHE_TTL_SECONDS=86400

# ── Compliance ───────────────────────────────────────────────────────
UNSUBSCRIBE_BASE_URL=https://debanshupaul.me/unsubscribe
