# ── Provider API keys ────────────────────────────────────────────────
OCEAN_API_KEY=
PROSPEO_API_KEY=

# Brevo: REST needs an API v3 key (xkeysib-...). If you only have an SMTP
# key (xsmtpsib-...), leave transport=auto and set BREVO_SMTP_LOGIN.
BREVO_API_KEY=
BREVO_TRANSPORT=auto        # auto | rest | smtp
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=           # your Brevo account login email (required for smtp transport)

# ── Sender identity (must be a verified sender on your domain) ────────
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME=Your Name
REPLY_TO_EMAIL=
TEST_RECIPIENT=          # if set, ALL outreach redirects here (safe demos); empty = real send

# ── Pipeline tuning ──────────────────────────────────────────────────
MOCK=false                  # true = use fake providers, spend zero credits
MAX_COMPANIES=15
MAX_CONTACTS_PER_COMPANY=5
PROSPECT_CONCURRENCY=5
RESOLVE_CONCURRENCY=5
SEND_CONCURRENCY=3

# ── Rate limits (requests/sec per provider, global token bucket) ─────
OCEAN_RPS=2
PROSPEO_RPS=2
BREVO_RPS=5

# ── Cache ────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_DIR=.cache
CACHE_TTL_SECONDS=86400

# ── Compliance ───────────────────────────────────────────────────────
UNSUBSCRIBE_BASE_URL=https://yourdomain.com/unsubscribe

# ── Supabase Auth (verifies the frontend's access tokens) ────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ── Infra (optional — defaults to SQLite + in-process) ───────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/conduit
# REDIS_URL=redis://localhost:6379/0
# DEV_MODE=true                 # set false in prod; then CORS_ORIGINS required
# CORS_ORIGINS=https://app.yourdomain.com
